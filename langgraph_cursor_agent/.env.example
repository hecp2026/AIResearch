# 复制这些字段到你的 shell 环境变量中。请勿提交真实的 API Key。
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5-mini

# 可选：兼容 OpenAI 官方协议的自建/第三方端点。
# OPENAI_BASE_URL=https://api.openai.com/v1

# run_command 工具允许执行的程序白名单（逗号分隔）。
AGENT_ALLOWED_COMMANDS=python,pytest,ruff,mypy

# 置为 1 时，写文件与运行命令前会触发人工审批（interrupt）。
AGENT_REQUIRE_APPROVAL=0
