# Copy values into your shell environment. Do not commit a real API key.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5-mini

# Optional: OpenAI-compatible endpoint that follows the official API shape.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Comma-separated executable allowlist for the run_command tool.
AGENT_ALLOWED_COMMANDS=python,pytest,ruff,mypy
